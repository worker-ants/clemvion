# pnpm config.
# node-linker=isolated: pnpm 기본 symlink(virtual store) 레이아웃. 각 패키지는 자기
# 매니페스트에 선언한 의존만 해소 가능하다 — hoisted(flat) 처럼 워크스페이스 전체가 단일
# node_modules 로 구체화되지 않으므로 phantom-dependency(선언 안 한 전이 의존을 import)가
# 빌드/런타임에서 fail-fast 로 드러난다. 마이그레이션은 hoisted 로 출발했다가 green 안정 후
# isolated 로 좁혔다(plan §3). 전환 과정에서 드러난 backend phantom(express·ip-address·dotenv·
# @jest/globals)은 직접 의존으로 선언해 해소. 내부 @workflow/* workspace 패키지는 isolated
# 에서도 symlink 로 유지되므로 frontend next.config 의 symlink 전제·Turbopack 우회(--webpack)는
# 불변이고, injected `pnpm deploy` 산출물도 동일하게 격리된다.
node-linker=isolated
# engines 는 프로젝트 정책상 advisory (engine-strict 미사용) — PROJECT.md §Node floor.
engine-strict=false
