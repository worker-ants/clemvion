# pnpm config.
# node-linker=hoisted: flat node_modules(npm 과 동일 레이아웃)을 유지한다.
# NestJS 의 reflection·plugin resolution, Next.js output:'standalone' file-tracer,
# 네이티브 모듈(isolated-vm/bcrypt) 의 phantom-dependency 가정과의 호환을 위해
# strict(isolated) symlink 대신 hoisted 로 출발한다. 그린 확인 후 점진 strict 화 가능.
node-linker=hoisted
# engines 는 프로젝트 정책상 advisory (engine-strict 미사용) — PROJECT.md §Node floor.
engine-strict=false
