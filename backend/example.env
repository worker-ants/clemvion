# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=workflow
DB_PASSWORD=workflow_dev
DB_DATABASE=workflow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=workflow-storage
S3_REGION=us-east-1

# App
APP_PORT=3011
APP_URL=http://localhost:3011
FRONTEND_URL=http://localhost:3002

# Email (dev: console transport / prod: smtp)
MAIL_TRANSPORT=console
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@example.com

# Worker
WORKER_CONCURRENCY=4

# Execution Engine
# Maximum number of times a single node can be re-executed in cyclic workflows.
# Set to 0 for unlimited iterations.
MAX_NODE_ITERATIONS=100

# Encryption key for credentials (32 bytes hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ---------------------------------------------------------------------------
# Integrations
# ---------------------------------------------------------------------------
# Secret used by the AES-256-GCM value transformer that encrypts
# integration.credentials and integration.last_error at rest.
# Any length is accepted (SHA-256 derives a 32-byte key).
# MUST be set in production; an unset value logs a warning and falls back to plaintext.
INTEGRATION_ENCRYPTION_KEY=dev-integration-encryption-secret-change-me

# When `true`, the OAuth callback returns synthetic tokens instead of calling
# real provider endpoints. Intended for local development.
OAUTH_STUB_MODE=true

# OAuth client credentials — required when OAUTH_STUB_MODE is false.
# Obtain these from each provider's developer console.
# GOOGLE/GITHUB credentials are shared between:
#   • Integration OAuth (/api/3rd-party/:provider/callback)
#   • User auth OAuth   (/api/auth/oauth/:provider/callback)
# Register BOTH redirect URIs in each provider's developer console.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Integration network safety (SSRF guard)
# ---------------------------------------------------------------------------
# `true` 로 두면 HTTP Request / DB Query 노드의 SSRF 가드(loopback · RFC 1918 ·
# link-local · IPv6 unique-local · cloud metadata 차단)가 비활성화된다.
# 내부 DB / on-prem API 를 호출해야 하는 self-hosted 배포에서만 의식적으로 true.
# 운영 환경에서는 외부 egress 방화벽이 있을 때만 활성화한다.
ALLOW_PRIVATE_HOST_TARGETS=false
