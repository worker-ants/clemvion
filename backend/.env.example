# Backend application environment variables (sample).
# Copy to backend/.env and adjust per environment.

# --- Database / cache (typically read from docker-compose-provided values) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=workflow
# DB_DATABASE=workflow
# DB_PASSWORD=...
# REDIS_HOST=localhost
# REDIS_PORT=6379

# --- Auth / app ---
# JWT_ACCESS_SECRET=...
# JWT_REFRESH_SECRET=...
# APP_PORT=3011
# APP_URL=http://localhost:3011
# FRONTEND_URL=http://localhost:3000

# --- Integration credentials encryption ---
# AES-256-GCM key derived via SHA-256 from this string.
# REQUIRED for production. Without it, Integration.credentials is stored in plaintext.
INTEGRATION_ENCRYPTION_KEY=change-me-to-a-32-byte-secret

# --- MCP (Model Context Protocol) ---
# Maximum concurrent connections opened to MCP servers per process.
# See spec/5-system/11-mcp-client.md §4.3.
MCP_MAX_CONCURRENT_CONNECTIONS=20

# Per-RPC timeouts in milliseconds (spec §4.4).
MCP_CONNECT_TIMEOUT_MS=10000
MCP_LIST_TIMEOUT_MS=10000
MCP_CALL_TIMEOUT_MS=30000

# Maximum bytes of MCP tool/resource/prompt response content before truncation
# (spec §8.1). Applies after JSON serialization.
MCP_MAX_RESPONSE_BYTES=102400

# Local-development escape hatch — bypasses the https:// requirement AND the
# SSRF host blocklist (loopback, RFC 1918, cloud metadata). Set to "true" only
# when running a sample MCP server on http://localhost during development.
#
# !! NEVER ENABLE IN PRODUCTION !!  With this flag a workspace admin can register
# any URL — including internal-only services and cloud metadata endpoints
# (e.g. http://169.254.169.254). This re-introduces the SSRF surface that the
# default policy is designed to block. The default value is "false".
MCP_ALLOW_INSECURE_URL=false
