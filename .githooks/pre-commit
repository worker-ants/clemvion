#!/usr/bin/env bash
# pre-commit hook — two version-controlled guards for every commit:
#   1. block commits on the default branch of the main worktree;
#   2. block commits that introduce malformed ```mermaid blocks in markdown.
#
# Activate with: `git config core.hooksPath .githooks`. The Claude Code
# SessionStart bootstrap (.claude/tools/bootstrap-session.sh) does this
# automatically; `scripts/setup-githooks.sh` does it manually.
#
# Both guards delegate to shared logic so this hook and the Claude Code
# hooks stay one source of truth: branch policy in
# .claude/hooks/_lib/branch_guard.py, mermaid parsing in
# .claude/tools/mermaid-lint/lint-mermaid.mjs.
#
# Failure mode: every guard fails open (allows the commit) if its tooling
# can't load — a broken guard must not block routine work. The Claude Code
# PreToolUse/PostToolUse hooks cover the same ground from the editor side.
# Override the branch guard with BYPASS_DEFAULT_BRANCH_GUARD=1 for a
# conscious default-branch commit (release tag, unavoidable hotfix).

set -u

# Locate the worktree top (for staged files) and the MAIN checkout (for
# tooling node_modules, which is gitignored and shared across worktrees).
repo_top=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
common=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
main_root=$(dirname "${common:-$repo_top/.git}")

# --- guard 1: default-branch block ------------------------------------
if [ "${BYPASS_DEFAULT_BRANCH_GUARD:-}" != "1" ]; then
    guard="$repo_top/.claude/hooks/_lib/branch_guard.py"
    if [ -f "$guard" ]; then
        # Exit code 2 means blocked; anything else (incl. crashes) allows.
        python3 "$guard"
        if [ "$?" -eq 2 ]; then
            echo "" >&2
            echo "Commit aborted by .githooks/pre-commit (branch guard)." >&2
            echo "Switch to a feature branch (or a worktree under .claude/worktrees/)," >&2
            echo "or set BYPASS_DEFAULT_BRANCH_GUARD=1 for this single commit." >&2
            exit 1
        fi
    fi
fi

# --- guard 2: mermaid syntax check ------------------------------------
# Lint staged markdown files only. Fails open if the tooling isn't ready.
# MERMAID_LINT_TOOL_DIR overrides the location (testing / unusual layouts).
mermaid_tool_dir="${MERMAID_LINT_TOOL_DIR:-$main_root/.claude/tools/mermaid-lint}"
mermaid_script="$mermaid_tool_dir/lint-mermaid.mjs"
if [ -d "$mermaid_tool_dir/node_modules" ] \
   && [ -f "$mermaid_script" ] && command -v node >/dev/null 2>&1; then
    # Staged Added/Copied/Modified markdown paths (NUL-delimited for safety).
    md_files=()
    while IFS= read -r -d '' f; do
        case "$f" in
            *.md|*.markdown|*.mdx) [ -f "$repo_top/$f" ] && md_files+=("$repo_top/$f") ;;
        esac
    done < <(git diff --cached --name-only --diff-filter=ACM -z)

    if [ "${#md_files[@]}" -gt 0 ]; then
        if ! node "$mermaid_script" "${md_files[@]}"; then
            echo "" >&2
            echo "Commit aborted by .githooks/pre-commit (mermaid lint)." >&2
            echo "Fix the malformed mermaid block(s) above and re-stage." >&2
            exit 1
        fi
    fi
fi

exit 0
