# Backend application environment variables (sample).
# Copy to codebase/backend/.env and adjust per environment.
#
# This file is the single reference for every variable the backend reads.
# Source of truth is codebase/backend/src/common/config/*.config.ts and process.env.*
# call sites. Keep this file in sync when adding or removing a variable.
#
# Convention:
#   - Non-secret variables show working dev defaults.
#   - Secrets show "change-me-*" placeholders — replace before running.
#   - Port/URL defaults match docker-compose.yml and codebase/frontend/.env (backend
#     listens on :3011, frontend on :3012). Code-level fallbacks differ in
#     a few places; .env values always take precedence.

# ---------------------------------------------------------------------------
# App / Network
# ---------------------------------------------------------------------------
NODE_ENV=development
APP_PORT=3011
APP_URL=http://localhost:3011
FRONTEND_URL=http://localhost:3012
# CORS allowlist — HTTP CORS + WebSocket gateway 가 동일 정책 사용 (W-1).
# 콤마 구분으로 여러 도메인 허용. 미설정 시 FRONTEND_URL 단일 도메인 fallback,
# 둘 다 미설정 + NODE_ENV=production 이면 부팅 거부 (보안 가드).
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Web chat widget — built-in CDN origin(s) always allowed for /api/external/* CORS,
# independent of any workspace's interactionAllowedOrigins (spec/7-channel-web-chat/
# 4-security §2·§2.1, 0-architecture §4). Comma-separated; parsed by parseWidgetOrigins
# (common/cors/web-chat-cors.ts) and read in main.ts.
# WEB_CHAT_WIDGET_ORIGINS=https://widget-cdn.example.com

# ---------------------------------------------------------------------------
# Database (Postgres)
# Defaults match docker-compose Postgres service (workflow / workflow_dev).
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=workflow
DB_PASSWORD=workflow_dev
DB_DATABASE=workflow

# ---------------------------------------------------------------------------
# Redis
# Set REDIS_PASSWORD when the deployment Redis enforces AUTH. Set
# REDIS_TLS=true (or use a rediss:// URL) for managed Redis offerings that
# require TLS. All Redis consumers (BullMQ, Health, nonce cache, continuation
# bus) read these via `redis.config.ts` and apply them uniformly.
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=change-me-when-auth-enabled
# REDIS_TLS=false

# ---------------------------------------------------------------------------
# Public Webhook Abuse Defense (spec/7-channel-web-chat/4-security §4)
# These control the rate-limit applied to *unauthenticated* (public) webhook
# triggers only. Authenticated triggers (authConfigId set) are not throttled.
# Redis must be available for these limits to take effect — service fail-opens
# (passes through) when Redis is unavailable.
#
#   PUBLIC_WEBHOOK_STARTUP_PER_MINUTE  分당 IP 시작 한도 (default: 10)
#   PUBLIC_WEBHOOK_HOURLY_NEW_MAX      시간당 누적 신규 대화 상한 (default: 20)
#   PUBLIC_WEBHOOK_MAX_BODY_BYTES      body 크기 제한 bytes (default: 32768 = 32KB)
#
# Config path: publicWebhook.* (src/common/config/public-webhook.config.ts or
#              mapped from these env vars via NestJS ConfigService).
# ---------------------------------------------------------------------------
# PUBLIC_WEBHOOK_STARTUP_PER_MINUTE=10
# PUBLIC_WEBHOOK_HOURLY_NEW_MAX=20
# PUBLIC_WEBHOOK_MAX_BODY_BYTES=32768


# ---------------------------------------------------------------------------
# JWT / Auth
# A single JWT_SECRET signs both access and refresh tokens.
# Production MUST override this with a long random value (>= 32 bytes).
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-jwt-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ---------------------------------------------------------------------------
# WebAuthn (Passkey · 보안 키) — 옵션 기능
# spec/5-system/1-auth.md §1.4.3.
# 두 핵심 환경변수(WEBAUTHN_RP_ID + WEBAUTHN_ORIGIN)가 모두 설정되어 있을 때만
# 기능이 활성화된다. 미설정 시 부팅은 정상이며 WebAuthn 엔드포인트만 503 으로
# 비활성화 — TOTP·일반 로그인은 그대로 동작.
# rpID 가 실제 운영 도메인과 어긋나면 등록된 credential 이 모두 무효화되므로
# 자동 폴백 없음. 운영 도메인을 정한 뒤 명시적으로 설정한다.
# ---------------------------------------------------------------------------
# WEBAUTHN_RP_ID=clemvion.example.com
# WEBAUTHN_RP_NAME=Clemvion
# WEBAUTHN_ORIGIN=https://clemvion.example.com,https://app.clemvion.example.com

# 개발·로컬·시연 한정 escape hatch — 위 두 환경변수가 미설정이어도 FRONTEND_URL 로
# 폴백해 기능을 켠다. **운영 환경에서는 사용 금지** (등록된 rpID 가 dev 도메인이 되어
# 운영 도메인으로 옮길 때 모든 credential 이 무효화됨).
# WEBAUTHN_ALLOW_FALLBACK=1

# ---------------------------------------------------------------------------
# S3 / Object Storage
# Defaults target the local MinIO instance from docker-compose.
# ---------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=workflow-storage
S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# Mail / SMTP
# MAIL_TRANSPORT:
#   console — (default) print emails to stdout instead of sending. Dev only.
#   smtp    — send via the SMTP credentials below.
# When MAIL_TRANSPORT=smtp, MAIL_HOST/PORT/USER/PASS are required.
# ---------------------------------------------------------------------------
MAIL_TRANSPORT=console
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@example.com

# ---------------------------------------------------------------------------
# Encryption
# ---------------------------------------------------------------------------
# AES-256-GCM master key. Encrypts more than LLM config:
#   - LLM provider config (API keys) — crypto.util
#   - Secret Store: Telegram/Slack/Discord bot tokens, trigger credentials,
#     and other secret:// refs — secret-crypto / SecretResolverService
# 32-byte hex (64 hex chars) recommended (otherwise derived via SHA-256).
# Empty value disables encryption (dev only — credentials stored in plaintext).
# NOTE: distinct from INTEGRATION_ENCRYPTION_KEY below (Integration OAuth creds).
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# AES-256-GCM key for Integration.credentials and Integration.last_error,
# derived via SHA-256 from this string (any length accepted).
# REQUIRED for production. Without it, credentials are stored in plaintext
# and the application logs a warning at boot.
INTEGRATION_ENCRYPTION_KEY=change-me-to-a-32-byte-secret

# ---------------------------------------------------------------------------
# Execution Engine
# ---------------------------------------------------------------------------
# Maximum re-executions of a single node in cyclic workflows.
# Set to 0 for unlimited iterations (engine logs a warning if back-edges exist).
MAX_NODE_ITERATIONS=100

# Graceful Shutdown — SIGTERM grace period (ms).
# W-15 fix (SUMMARY#W-15): k8s terminationGracePeriodSeconds = ceil(SIGTERM_GRACE_MS/1000) + 5.
# Non-positive or non-numeric values fall back to 30000.
SIGTERM_GRACE_MS=30000

# Continuation worker concurrency — how many resume/continuation jobs the
# `execution-continuation` BullMQ worker processes in parallel per instance
# (spec/5-system/4-execution-engine.md §7.4 / §11).
# Default 1 (sequential). Raise only if large bursts of concurrent resumes make
# the per-job setup (rehydration / graph build) serialize visibly in production.
# Non-positive, non-integer, or non-numeric values fall back to 1.
# Read once at module load — changing it requires an instance restart.
CONTINUATION_WORKER_CONCURRENCY=1

# Parallel execution mode for the Parallel logic node.
#   v1  — (default) ParallelExecutor runs each branch concurrently via
#         Promise.allSettled with p-limit (respects maxConcurrency). Blocking
#         nodes and back-edges are forbidden inside branches.
#   off — Rollback card: legacy sequential behavior — Parallel node fans-out
#         via port array but the engine executes downstream branches
#         sequentially in topological order. Use only when reverting from a
#         ParallelExecutor regression.
PARALLEL_ENGINE=v1

# ---------------------------------------------------------------------------
# OAuth — shared between Integration OAuth and User Auth OAuth
# ---------------------------------------------------------------------------
# Each provider's client credentials are reused for BOTH:
#   • Integration OAuth callback  /api/3rd-party/:provider/callback
#   • User auth OAuth callback    /api/auth/oauth/:provider/callback
# Register BOTH redirect URIs in each provider's developer console.
#
# OAUTH_STUB_MODE=true returns synthetic tokens instead of calling the real
# provider endpoints. Intended for local development.
# !! Boot fails if NODE_ENV=production AND OAUTH_STUB_MODE=true. !!
OAUTH_STUB_MODE=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cafe24 OAuth (public app). Used when an integration is created with
# App Type=Public. Private apps supply their own client_id/secret per
# integration via the Step 2 form and do NOT consult these env vars.
# Leave blank in dev to force every integration to use Private mode.
CAFE24_CLIENT_ID=
CAFE24_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# MCP (Model Context Protocol)
# See spec/5-system/11-mcp-client.md.
# ---------------------------------------------------------------------------
# Maximum concurrent connections opened to MCP servers per process (§4.3).
MCP_MAX_CONCURRENT_CONNECTIONS=20

# Per-RPC timeouts in milliseconds (§4.4).
MCP_CONNECT_TIMEOUT_MS=10000
MCP_LIST_TIMEOUT_MS=10000
MCP_CALL_TIMEOUT_MS=30000

# Maximum bytes of MCP tool/resource/prompt response content before
# truncation (§8.1). Applies after JSON serialization.
MCP_MAX_RESPONSE_BYTES=102400

# Local-development escape hatch — bypasses the https:// requirement AND the
# SSRF host blocklist (loopback, RFC 1918, cloud metadata). Set to "true"
# only when running a sample MCP server on http://localhost during dev.
#
# !! NEVER ENABLE IN PRODUCTION !!  With this flag a workspace admin can
# register any URL — including internal-only services and cloud metadata
# endpoints (e.g. http://169.254.169.254). This re-introduces the SSRF
# surface that the default policy is designed to block.
MCP_ALLOW_INSECURE_URL=false

# ---------------------------------------------------------------------------
# Integration network safety (SSRF guard)
# Applies to outbound calls made by the HTTP Request and DB Query nodes
# (see codebase/backend/src/nodes/integration/http-request/http-safety.ts).
# ---------------------------------------------------------------------------
# When `true`, disables the SSRF host-resolution guard so that
# integration-backed nodes (HTTP Request / Database Query / Send Email SMTP)
# can target loopback / RFC 1918 / link-local / CGNAT / IPv6 unique-local
# addresses. Required for self-hosted deployments that legitimately need to
# reach internal DBs, on-prem APIs, or internal SMTP relays.
#
# !! NEVER ENABLE IN PRODUCTION UNLESS YOU HAVE AN EXTERNAL EGRESS FIREWALL !!
# Without this flag, a workspace author can pivot from an Integration
# credential to internal infrastructure (cloud metadata, internal services)
# via attacker-controlled hostnames or DNS rebinding.
ALLOW_PRIVATE_HOST_TARGETS=false

# ---------------------------------------------------------------------------
# Observability (OpenTelemetry)
# When OTEL_ENABLED=true the backend exports OTLP/HTTP traces on boot
# (see src/instrumentation.ts).
# ---------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=clemvion-backend

# ---------------------------------------------------------------------------
# System Status — queue health thresholds
# Used by SystemStatusService.deriveHealth() (spec/5-system/16-system-status-api.md §3).
# ---------------------------------------------------------------------------
# Number of failed jobs in a queue required to mark health as "degraded".
# Default 1 (any failure triggers degraded). Raise in high-throughput environments
# where transient failures are expected and quickly retried.
# NOTE: this now compares against recentFailed (failures within
# SYSTEM_STATUS_FAILED_WINDOW_MINUTES), not the retained cumulative failed count.
SYSTEM_STATUS_FAILED_THRESHOLD=1

# Number of delayed jobs in a queue required to mark health as "degraded".
# Default 50. Raise if large delayed-job backlogs are normal for your deployment.
SYSTEM_STATUS_DELAYED_THRESHOLD=50

# Recency window (minutes) for the "recentFailed" metric and the failed-based
# "degraded" health rule. Only failures with finishedOn within this window count.
# Default 60. NOTE: SYSTEM_STATUS_FAILED_THRESHOLD now compares against recentFailed
# (this window), not the retained cumulative failed count — review your threshold.
SYSTEM_STATUS_FAILED_WINDOW_MINUTES=60

# Per-queue cap on how many failed jobs are scanned (newest→oldest) when computing
# recentFailed. On reaching the cap, recentFailed is treated as a lower bound.
# Default 1000. Bounds the Redis cost of the getFailed() scan — keep it modest
# (e.g. <= 10000); very large values let a big failed set blow up the per-poll scan.
SYSTEM_STATUS_FAILED_SCAN_CAP=1000
