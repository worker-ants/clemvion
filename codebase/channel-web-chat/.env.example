# channel-web-chat (위젯 SPA, Next.js CSR) environment variables (sample).
# Copy to codebase/channel-web-chat/.env and adjust per environment.
#
# Convention:
#   - NEXT_PUBLIC_* are inlined into the client bundle at build time.
#   - PORT is read by the dev script in package.json only.
#   - Defaults assume the backend runs on :3011 (see codebase/backend/.env.example)
#     and the frontend on :3012 (see codebase/frontend/.env.example).

# ---------------------------------------------------------------------------
# Dev server port
# The `dev` script falls back to 3013 when PORT is unset
# (`source .env 2>/dev/null; next dev --port ${PORT:-3013}`). 3013 avoids
# collision with the default Next.js port (3000), backend (3011) and
# frontend (3012).
# ---------------------------------------------------------------------------
PORT=3013

# ---------------------------------------------------------------------------
# Demo host route (/demo)
# The dev-only demo host (src/app/demo) is enabled automatically under
# `next dev` (NODE_ENV=development) and excluded from the production static
# export (`next build`). Set this to 1 only if you need to preview /demo
# against a production build.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_ENABLE_DEMO=1

# ---------------------------------------------------------------------------
# Base path
# When the widget is served under a sub-path (e.g. /web-chat/v1/app) set this
# so the demo iframe and asset URLs resolve correctly (0-architecture §4).
# Leave unset for local development (served at /).
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_BASE_PATH="/web-chat/v1/app"
