{
  "name": "@workflow/chat-channel-validation",
  "version": "0.1.0",
  "description": "Shared validation constants for chat-channel provider-issued plaintext (Slack signing secret / Discord ed25519 public key). SoT: spec/4-nodes/7-trigger/providers/{slack,discord}.md §6.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "[ -d dist ] || tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/jest": "^30.0.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.2.5"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
