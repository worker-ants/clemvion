{
  "name": "@workflow/sdk",
  "version": "0.1.0",
  "description": "Clemvion External Interaction API client SDK — trigger workflows, subscribe to SSE events, submit interactions, verify outbound notification signatures.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "node -e \"require('fs').existsSync('dist')||require('child_process').execSync('tsc',{stdio:'inherit'})\"",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.4.10"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": ["dist", "README.md"],
  "keywords": ["clemvion", "workflow", "webhook", "sse", "automation"],
  "license": "Apache-2.0",
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
