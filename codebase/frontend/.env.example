# Frontend (Next.js) environment variables (sample).
# Copy to codebase/frontend/.env and adjust per environment.
#
# This file lists every variable the frontend reads, including server-only
# variables that don't carry the NEXT_PUBLIC_ prefix.
#
# Convention:
#   - NEXT_PUBLIC_* are inlined into the client bundle at build time.
#   - Other vars are read on the Node.js server only (Server Components,
#     route handlers, next.config.ts, package.json scripts).
#   - Defaults assume the backend runs on :3011 (see codebase/backend/.env.example).

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
NODE_ENV=development

# Dev/start scripts in package.json fall back to 3000 if PORT is unset
# (`source .env 2>/dev/null; next dev --port ${PORT:-3000}`). Project
# convention is :3012 to avoid collision with the default Next.js port.
PORT=3012

# ---------------------------------------------------------------------------
# Backend API endpoints (client-exposed — baked into the bundle)
# Must match the backend's APP_URL.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3011/api"
NEXT_PUBLIC_WS_URL="http://localhost:3011"

# ---------------------------------------------------------------------------
# Inbound webhook URL base (client-exposed — baked into the bundle)
# Used by the triggers UI to display/copy the full webhook URL
# (`{base}/api/hooks/{endpointPath}`, spec WH-EP-02). The endpoint is served
# by the backend, so this must point at the backend's public origin.
# When unset, the base is derived from NEXT_PUBLIC_API_URL (its `/api` suffix
# stripped), then falls back to the browser's window.location.origin.
# Set this only when the webhook ingress host differs from the API host.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_WEBHOOK_BASE_URL="https://hooks.example.com"

# ---------------------------------------------------------------------------
# Web chat widget origin (client-exposed — baked into the bundle)
# Base origin under which the embedded web-chat widget is served
# (`{base}/web-chat/v1/loader.js` + iframe app). The web-chat console uses it
# for the install snippet and live preview (spec 7-channel-web-chat
# 5-admin-console §5, 0-architecture §4·§4.1).
# When UNSET (default), the widget is served co-deployed under the app's own
# origin at `/_widget/web-chat/v1/` (window.location.origin + /_widget) — so
# self-hosting needs no separate CDN. Set this only to serve the widget from a
# dedicated edge CDN; the value must match the backend WEB_CHAT_WIDGET_ORIGINS
# CORS allowlist origin.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_WIDGET_CDN_BASE="https://cdn.example.com"

# ---------------------------------------------------------------------------
# Server-only API endpoint
# Used by Server Components and route handlers when the frontend talks to
# the backend over a cluster-internal network (e.g. Kubernetes service DNS).
# When unset, server-side fetches fall back to NEXT_PUBLIC_API_URL.
# Leave commented for local development.
# ---------------------------------------------------------------------------
# INTERNAL_API_URL="http://backend:3011/api"

# ---------------------------------------------------------------------------
# Dev-only CORS origin allowlist for next.config.ts.
# Multiple origins may be supplied as a comma-separated list.
# ---------------------------------------------------------------------------
ALLOWED_DEV_ORIGIN="localhost:3012"
